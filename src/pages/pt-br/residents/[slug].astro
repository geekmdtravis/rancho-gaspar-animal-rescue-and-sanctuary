---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnimalProfile from '../../../components/AnimalProfile.astro';
import { listAnimals, animalSlug } from '../../../lib/animals';

export async function getStaticPaths() {
  const animals = await listAnimals('pt-br', 'resident');
  return animals.map((entry) => ({ params: { slug: animalSlug(entry) }, props: { entry } }));
}

const { entry } = Astro.props;
---

<BaseLayout
  lang="pt-br"
  active="residents"
  title={entry.data.name}
  description={entry.data.summary}
>
  <AnimalProfile lang="pt-br" entry={entry} />
</BaseLayout>
