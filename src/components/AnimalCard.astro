---
// AnimalCard — the portrait card used in adoptable/resident grids. When the
// animal has an optimized cover image it renders <Image> (responsive widths +
// lazy + blur-friendly); otherwise it falls back to the illustrated PhotoSlot
// so the page looks intentional before real photos are uploaded.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PhotoSlot from './PhotoSlot.astro';
import Badge from './Badge.astro';
import Button from './Button.astro';
import Heart from './icons/Heart.astro';

interface Props {
  name: string;
  kind?: 'dog' | 'cat' | 'bunny';
  sex?: string;
  age?: string;
  description?: string;
  status?: 'adoptable' | 'resident';
  statusLabel: string;
  meetLabel: string;
  tags?: string[];
  href: string;
  image?: ImageMetadata;
  imageAlt?: string;
}
const {
  name,
  kind = 'dog',
  sex,
  age,
  description,
  status = 'adoptable',
  statusLabel,
  meetLabel,
  tags = [],
  href,
  image,
  imageAlt,
} = Astro.props;

const tagVariants = ['soft', 'sage', 'sky', 'lilac'] as const;
const meetCta = `${meetLabel} ${name}`;
---

<article class:list={['acard', status === 'resident' && 'acard--resident']}>
  <a class="acard__media" href={href} aria-label={meetCta}>
    {
      image ? (
        <Image
          src={image}
          alt={imageAlt ?? name}
          widths={[180, 320, 480, 640]}
          sizes="(max-width: 640px) 90vw, 300px"
          class="acard__img"
          loading="lazy"
        />
      ) : (
        <PhotoSlot ratio="1 / 1" radius={0} kind={kind} label={`${name} photo`} />
      )
    }
    <span class="acard__status">
      <Badge variant={status === 'resident' ? 'lilac' : 'primary'} size="sm">{statusLabel}</Badge>
    </span>
    <span class="acard__heart" aria-hidden="true"
      ><Heart size={16} color="var(--rg-primary)" /></span
    >
  </a>
  <div class="acard__body">
    <div class="acard__head">
      <h3 class="acard__name">{name}</h3>
      {(sex || age) && <span class="acard__meta">{[sex, age].filter(Boolean).join(' • ')}</span>}
    </div>
    {description && <p class="acard__desc">{description}</p>}
    {
      tags.length > 0 && (
        <div class="acard__tags">
          {tags.map((tag, i) => (
            <Badge variant={tagVariants[i % tagVariants.length]} size="sm">
              {tag}
            </Badge>
          ))}
        </div>
      )
    }
    <Button href={href} size="sm" variant="primary" block>{meetCta}</Button>
  </div>
</article>

<style>
  .acard {
    background: var(--rg-surface);
    border-radius: 18px;
    border: 1px solid var(--rg-border);
    overflow: hidden;
    transition:
      box-shadow 0.2s,
      transform 0.2s;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
    display: flex;
    flex-direction: column;
  }
  .acard:hover {
    box-shadow: var(--rg-shadow-card-hover);
    transform: translateY(-3px);
  }
  .acard__media {
    position: relative;
    display: block;
  }
  .acard__img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
  .acard__status {
    position: absolute;
    top: 12px;
    left: 12px;
  }
  .acard__heart {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
  }
  .acard__body {
    padding: 16px;
  }
  .acard__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }
  .acard__name {
    margin: 0;
    font-family: var(--rg-font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--rg-ink);
  }
  .acard__meta {
    font-size: 12px;
    font-weight: 600;
    color: var(--rg-ink-mute);
    white-space: nowrap;
  }
  .acard__desc {
    margin: 6px 0 12px;
    font-size: 13px;
    color: var(--rg-ink-soft);
    line-height: 1.5;
  }
  .acard__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
</style>
