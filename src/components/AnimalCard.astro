---
// AnimalCard — the portrait card used in adoptable/resident grids. When the
// animal has an optimized cover image it renders <Image> (responsive widths +
// lazy + blur-friendly); otherwise it falls back to the illustrated PhotoSlot
// so the page looks intentional before real photos are uploaded.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PhotoSlot from './PhotoSlot.astro';
import Badge from './Badge.astro';
import Button from './Button.astro';
import Heart from './icons/Heart.astro';
import Icon from './icons/Icon.astro';
import { formatAge, type Lang } from '../i18n/utils';

interface Props {
  name: string;
  kind?: 'dog' | 'cat' | 'bunny';
  sex?: string;
  dob?: Date;
  dobEstimated?: boolean;
  lang: Lang;
  description?: string;
  status?: 'adoptable' | 'resident';
  statusLabel: string;
  meetLabel: string;
  tags?: string[];
  href: string;
  image?: ImageMetadata;
  imageAlt?: string;
}
const {
  name,
  kind = 'dog',
  sex,
  dob,
  dobEstimated = true,
  lang,
  description,
  status = 'adoptable',
  statusLabel,
  meetLabel,
  tags = [],
  href,
  image,
  imageAlt,
} = Astro.props;

const tagVariants = ['soft', 'sage', 'sky', 'lilac'] as const;
const meetCta = `${meetLabel} ${name}`;
const shareLabel = lang === 'pt-br' ? `Compartilhar ${name}` : `Share ${name}`;
const copiedLabel = lang === 'pt-br' ? 'Link copiado' : 'Link copied';
const age = formatAge(dob, dobEstimated, lang);
---

<article class:list={['acard', status === 'resident' && 'acard--resident']}>
  <a class="acard__media" href={href} aria-label={meetCta}>
    {
      image ? (
        <span class="acard__imgwrap">
          <Image
            src={image}
            alt={imageAlt ?? name}
            widths={[180, 320, 480, 640]}
            sizes="(max-width: 640px) 90vw, 300px"
            class="acard__img"
            loading="lazy"
          />
        </span>
      ) : (
        <PhotoSlot ratio="1 / 1" radius={0} kind={kind} label={`${name} photo`} />
      )
    }
    <span class="acard__status">
      <Badge variant={status === 'resident' ? 'lilac' : 'primary'} size="sm">{statusLabel}</Badge>
    </span>
  </a>
  {
    status === 'adoptable' ? (
      <button
        class="acard__share"
        type="button"
        aria-label={shareLabel}
        title={shareLabel}
        data-share-url={href}
        data-share-title={meetCta}
        data-share-text={description ?? meetCta}
        data-share-copied={copiedLabel}
      >
        <span class="acard__share-icon acard__share-icon--share">
          <Icon name="share" size={16} />
        </span>
        <span class="acard__share-icon acard__share-icon--check">
          <Icon name="check" size={16} />
        </span>
        <span class="acard__share-feedback" aria-hidden="true">
          {copiedLabel}
        </span>
      </button>
    ) : (
      <span class="acard__heart" aria-hidden="true">
        <Heart size={16} color="var(--rg-primary)" />
      </span>
    )
  }
  <div class="acard__body">
    <div class="acard__head">
      <h3 class="acard__name">{name}</h3>
      {(sex || age) && <span class="acard__meta">{[sex, age].filter(Boolean).join(' • ')}</span>}
    </div>
    {description && <p class="acard__desc">{description}</p>}
    {
      tags.length > 0 && (
        <div class="acard__tags">
          {tags.map((tag, i) => (
            <Badge variant={tagVariants[i % tagVariants.length]} size="sm">
              {tag}
            </Badge>
          ))}
        </div>
      )
    }
    <Button href={href} size="sm" variant="primary" block>{meetCta}</Button>
  </div>
</article>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-share-url]').forEach((button) => {
    if (button.dataset.shareReady === 'true') return;
    button.dataset.shareReady = 'true';

    button.addEventListener('click', async () => {
      const url = new URL(button.dataset.shareUrl ?? '/', window.location.href).toString();
      const title = button.dataset.shareTitle ?? document.title;
      const text = button.dataset.shareText;
      const payload = { title, text, url };

      try {
        if (navigator.share) {
          await navigator.share(payload);
          return;
        }
        if (!navigator.clipboard) return;
        await navigator.clipboard.writeText(url);
        const originalLabel = button.getAttribute('aria-label') ?? title;
        const copiedLabel = button.dataset.shareCopied ?? 'Link copied';
        button.classList.add('is-copied');
        button.setAttribute('aria-label', copiedLabel);
        button.setAttribute('title', copiedLabel);
        window.setTimeout(() => {
          button.classList.remove('is-copied');
          button.setAttribute('aria-label', originalLabel);
          button.setAttribute('title', originalLabel);
        }, 1800);
      } catch {
        // User cancellation or unavailable clipboard: leave the page unchanged.
      }
    });
  });
</script>

<style>
  .acard {
    position: relative;
    background: var(--rg-surface);
    border-radius: 18px;
    border: 1px solid var(--rg-border);
    overflow: hidden;
    transition:
      box-shadow 0.2s,
      transform 0.2s;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
    display: flex;
    flex-direction: column;
  }
  .acard:hover {
    box-shadow: var(--rg-shadow-card-hover);
    transform: translateY(-3px);
  }
  .acard__media {
    position: relative;
    display: block;
  }
  /* The wrapper (a real element I control) enforces the square crop; the image
     just fills it. This is robust regardless of the width/height attributes
     Astro's <Image> emits. :global reaches the <img> inside the component. */
  .acard__imgwrap {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .acard__imgwrap :global(.acard__img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .acard__status {
    position: absolute;
    top: 12px;
    left: 12px;
  }
  .acard__heart {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    display: grid;
    place-items: center;
    backdrop-filter: blur(8px);
  }
  .acard__share {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    width: 34px;
    height: 34px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 999px;
    appearance: none;
    background: rgba(255, 255, 255, 0.92);
    color: var(--rg-primary-deep);
    display: grid;
    place-items: center;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition:
      background 0.15s,
      color 0.15s,
      transform 0.15s;
  }
  .acard__share-feedback {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    pointer-events: none;
    white-space: nowrap;
    border-radius: 999px;
    background: var(--rg-ink);
    color: #fff;
    padding: 5px 9px;
    font-size: 11px;
    font-weight: 800;
    line-height: 1;
    opacity: 0;
    transform: translateY(-3px);
    transition:
      opacity 0.15s,
      transform 0.15s;
  }
  .acard__share-icon {
    display: inline-flex;
    grid-area: 1 / 1;
    transition:
      opacity 0.15s,
      transform 0.15s;
  }
  .acard__share-icon--check {
    opacity: 0;
    transform: scale(0.7);
  }
  .acard__share:hover,
  .acard__share.is-copied {
    background: var(--rg-primary);
    color: #fff;
    transform: translateY(-1px);
  }
  .acard__share.is-copied .acard__share-icon--share {
    opacity: 0;
    transform: scale(0.7);
  }
  .acard__share.is-copied .acard__share-icon--check {
    opacity: 1;
    transform: scale(1);
  }
  .acard__share.is-copied .acard__share-feedback {
    opacity: 1;
    transform: translateY(0);
  }
  .acard__body {
    padding: 16px;
  }
  .acard__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }
  .acard__name {
    margin: 0;
    font-family: var(--rg-font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--rg-ink);
  }
  .acard__meta {
    font-size: 12px;
    font-weight: 600;
    color: var(--rg-ink-mute);
    white-space: nowrap;
  }
  .acard__desc {
    margin: 6px 0 12px;
    font-size: 13px;
    color: var(--rg-ink-soft);
    line-height: 1.5;
  }
  .acard__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
</style>
