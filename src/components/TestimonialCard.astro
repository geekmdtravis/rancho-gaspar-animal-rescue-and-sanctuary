---
// TestimonialCard — quote + star rating + author, with an avatar. Ported from
// components-blocks.jsx TestimonialCard.
import Avatar from './Avatar.astro';

interface Props {
  quote: string;
  author: string;
  role?: string;
  rating?: number;
  kind?: 'dog' | 'cat' | 'bunny';
  // Pre-formatted "Translated from X" label, set only when the review is shown
  // off its origin language. Undefined = original language, no badge.
  translatedFrom?: string;
  // The review's original-language content, supplied only for translated cards
  // so the reader can toggle to what the person actually wrote.
  original?: { quote: string; author: string; role?: string };
  showOriginalLabel?: string;
  showTranslationLabel?: string;
}
const {
  quote,
  author,
  role,
  rating = 5,
  kind = 'dog',
  translatedFrom,
  original,
  showOriginalLabel,
  showTranslationLabel,
} = Astro.props;
const stars = Array.from({ length: 5 }, (_, i) => i < rating);
// Only offer the toggle when we actually have an original to switch to.
const canToggle = Boolean(original && showOriginalLabel && showTranslationLabel);
---

<figure
  class="tcard"
  data-tcard
  data-trans-quote={canToggle ? quote : undefined}
  data-orig-quote={canToggle ? original!.quote : undefined}
  data-trans-author={canToggle ? author : undefined}
  data-orig-author={canToggle ? original!.author : undefined}
  data-trans-role={canToggle ? (role ?? '') : undefined}
  data-orig-role={canToggle ? (original!.role ?? '') : undefined}
>
  <div class="tcard__body">
    <div class="tcard__mark" aria-hidden="true">&ldquo;</div>
    <blockquote class="tcard__quote" data-tcard-quote>{quote}</blockquote>
    <div class="tcard__stars" aria-label={`${rating} out of 5`}>
      {
        stars.map((filled) => (
          <svg
            width="14"
            height="14"
            viewBox="0 0 16 16"
            fill={filled ? 'currentColor' : 'none'}
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M8 1l2.2 4.5 4.8.7-3.5 3.4.8 4.9L8 12.2 3.7 14.5l.8-4.9L1 6.2l4.8-.7L8 1z" />
          </svg>
        ))
      }
    </div>
    <figcaption>
      <div class="tcard__author" data-tcard-author>{author}</div>
      {
        role && (
          <div class="tcard__role" data-tcard-role>
            {role}
          </div>
        )
      }
      {
        translatedFrom && (
          <div class="tcard__meta">
            <div class="tcard__translated" title={translatedFrom}>
              <svg
                width="11"
                height="11"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M2 4h7M5.5 2.5V4M7 4c0 3-2.2 5.5-5 6.5M3.5 7.5c.5 1.5 2 2.8 3.5 3.3" />
                <path d="M9 14l3-7 3 7M10 11.5h4" />
              </svg>
              <span>{translatedFrom}</span>
            </div>
            {canToggle && (
              <button
                type="button"
                class="tcard__toggle"
                data-tcard-toggle
                data-label-original={showOriginalLabel}
                data-label-translation={showTranslationLabel}
                aria-pressed="false"
              >
                {showOriginalLabel}
              </button>
            )}
          </div>
        )
      }
    </figcaption>
  </div>
  <Avatar kind={kind} size={64} ring />
</figure>

<script>
  // Translated cards can flip between the on-screen translation and the original
  // text the reviewer wrote. Both strings ride along in data attributes, so the
  // swap is a no-framework text replace — and the translation still renders with
  // JS off (progressive enhancement).
  document.querySelectorAll<HTMLElement>('[data-tcard]').forEach((card) => {
    const btn = card.querySelector<HTMLButtonElement>('[data-tcard-toggle]');
    if (!btn) return;
    const quoteEl = card.querySelector<HTMLElement>('[data-tcard-quote]');
    const authorEl = card.querySelector<HTMLElement>('[data-tcard-author]');
    const roleEl = card.querySelector<HTMLElement>('[data-tcard-role]');
    const d = card.dataset;
    let showingOriginal = false;

    btn.addEventListener('click', () => {
      showingOriginal = !showingOriginal;
      if (quoteEl)
        quoteEl.textContent = showingOriginal ? (d.origQuote ?? '') : (d.transQuote ?? '');
      if (authorEl)
        authorEl.textContent = showingOriginal ? (d.origAuthor ?? '') : (d.transAuthor ?? '');
      if (roleEl) roleEl.textContent = showingOriginal ? (d.origRole ?? '') : (d.transRole ?? '');
      btn.textContent = showingOriginal
        ? (btn.dataset.labelTranslation ?? '')
        : (btn.dataset.labelOriginal ?? '');
      btn.setAttribute('aria-pressed', String(showingOriginal));
    });
  });
</script>

<style>
  .tcard {
    margin: 0;
    background: var(--rg-surface);
    border-radius: 18px;
    padding: 24px;
    border: 1px solid var(--rg-border);
    font-family: var(--rg-font-body);
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .tcard__body {
    flex: 1;
  }
  .tcard__mark {
    font-size: 36px;
    color: var(--rg-primary-soft);
    font-family: var(--rg-font-display);
    line-height: 0.8;
    margin-bottom: -6px;
  }
  .tcard__quote {
    margin: 0;
    font-family: var(--rg-font-display);
    font-size: 17px;
    line-height: 1.5;
    color: var(--rg-ink);
    font-style: italic;
  }
  .tcard__stars {
    display: flex;
    gap: 2px;
    margin-top: 12px;
    color: var(--rg-primary);
  }
  .tcard__author {
    margin-top: 10px;
    font-size: 14px;
    font-weight: 700;
    color: var(--rg-ink);
  }
  .tcard__role {
    font-size: 12px;
    color: var(--rg-ink-mute);
  }
  .tcard__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .tcard__translated {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 999px;
    background: var(--rg-primary-faint);
    color: var(--rg-primary-deep);
    font-size: 11px;
    font-weight: 600;
    font-style: normal;
  }
  .tcard__translated svg {
    flex-shrink: 0;
  }
  .tcard__toggle {
    padding: 0;
    border: none;
    background: none;
    color: var(--rg-primary-deep);
    font-family: inherit;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .tcard__toggle:hover {
    color: var(--rg-primary);
  }
</style>
