---
// AnimalProfile — a single animal's page. Adapts to status: adoptable shows an
// "Apply to adopt" CTA, adoption fee, foster note, and the adoption-process
// accordion; resident shows a clear "permanent resident, not for adoption"
// callout instead. Both get the story, quick facts, a sponsor widget, and
// similar animals.
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import Breadcrumbs from './Breadcrumbs.astro';
import SectionLabel from './SectionLabel.astro';
import Badge from './Badge.astro';
import Button from './Button.astro';
import Accordion from './Accordion.astro';
import DonationWidget from './DonationWidget.astro';
import AnimalCard from './AnimalCard.astro';
import PhotoSlot from './PhotoSlot.astro';
import Heart from './icons/Heart.astro';
import Icon from './icons/Icon.astro';
import { t, localizePath, formatAge, formatLifespan, type Lang } from '../i18n/utils';
import {
  similarAnimals,
  animalPath,
  animalRoute,
  isDeceased,
  isAdopted,
  type Animal,
} from '../lib/animals';
import FxAmount from './FxAmount.astro';

interface Props {
  lang: Lang;
  entry: Animal;
}
const { lang, entry } = Astro.props;
const dict = t(lang);
const d = entry.data;
// Four lifecycle states drive the whole page. Deceased takes precedence, then
// adopted; otherwise the stored status decides.
const deceased = isDeceased(entry);
const adopted = isAdopted(entry);
const isResident = !deceased && d.status === 'resident';
const isAvailable = !deceased && !adopted && d.status === 'adoptable';
// The animal lives under /adopt or /residents (memorials route to residents).
const route = animalRoute(entry);
const isAdopt = route === 'adopt';
// The adoption machinery (apply CTA, fee, foster note, process steps) is only
// meaningful for an animal actually up for adoption right now. Sponsoring
// applies to any living animal in our care.
const showSponsor = isAvailable || isResident;

const { Content } = await render(entry);
const similar = await similarAnimals(entry, lang);

const statusLabel = deceased
  ? dict.status.inMemoriam
  : adopted
    ? dict.status.adopted
    : isResident
      ? dict.status.resident
      : dict.status.adoptable;
const statusVariant = deceased || isResident ? 'lilac' : adopted ? 'success' : 'primary';
// Memorials show a birth–death span in place of a current age.
const lifespan = formatLifespan(d.dob, d.dobEstimated, d.dod);
const ageOrSpan = deceased ? lifespan : formatAge(d.dob, d.dobEstimated, lang);
const meta = [d.sex === 'unknown' ? null : d.sex, ageOrSpan, d.breed, d.weight].filter(Boolean);
// Adoption fee is authored in USD; shown USD-first with an approximate BRL
// value fetched in-browser (see FxAmount). Kept out of the plain-text quick
// facts so its BRL slot can be a live component rather than a baked string.
// Only shown while the animal is actually available.
const facts = d.quickFacts;
const feeUsd = isAvailable && d.adoptionFee ? d.adoptionFee : null;

const crumbs = [
  { label: dict.nav.home, href: localizePath('/', lang) },
  {
    label: isAdopt ? dict.adoptPage.breadcrumb : dict.residentsPage.breadcrumb,
    href: localizePath(isAdopt ? '/adopt' : '/residents', lang),
  },
  { label: d.name },
];

const applyLabel = `${dict.profile.apply} ${d.name}`;
const aboutHeading = `${dict.profile.aboutHeading} ${d.name}`;
const shareLabel = `${dict.profile.share} ${d.name}`;
const copiedLabel = lang === 'pt-br' ? 'Link copiado' : 'Link copied';
const applyHref = `mailto:ranchogasparsanctuary@gmail.com?subject=${encodeURIComponent(applyLabel)}`;
const backHref = localizePath(isAdopt ? '/adopt' : '/residents', lang);
const backLabel = isAdopt ? dict.profile.backAdopt : dict.profile.backResidents;
---

<section class="rg-container rg-section--tight">
  <Breadcrumbs items={crumbs} />

  <div class="ap-top">
    <!-- Gallery -->
    <div class="ap-gallery">
      {
        d.cover ? (
          <span class="ap-hero">
            <Image
              src={d.cover}
              alt={d.coverAlt ?? d.name}
              widths={[480, 768, 1024]}
              sizes="(max-width: 980px) 92vw, 560px"
              class="ap-hero-img"
            />
          </span>
        ) : (
          <PhotoSlot ratio="4 / 3" radius={20} kind={d.species} label={`${d.name} · photo`} />
        )
      }
      {
        d.gallery.length > 0 && (
          <div class="ap-thumbs">
            {d.gallery.slice(0, 4).map((img, i) => (
              <span class="ap-thumb">
                <Image
                  src={img}
                  alt={`${d.name} ${i + 1}`}
                  widths={[120, 240]}
                  sizes="120px"
                  class="ap-thumb-img"
                />
              </span>
            ))}
          </div>
        )
      }
    </div>

    <!-- Detail panel -->
    <div class="ap-panel">
      <div class="ap-badges">
        <Badge variant={statusVariant}>{statusLabel}</Badge>
        {d.tags.map((tag) => <Badge variant="sage">{tag}</Badge>)}
      </div>

      <h1 class="ap-name rg-display">
        {d.name}
        <span class="ap-name-heart"><Heart size={24} color="var(--rg-primary)" /></span>
      </h1>
      {meta.length > 0 && <p class="ap-meta">{meta.join(' · ')}</p>}

      {
        isResident && (
          <div class="ap-resident-note">
            <Heart size={16} color="var(--rg-primary-deep)" filled />
            <span>{dict.status.residentNote}</span>
          </div>
        )
      }
      {
        adopted && (
          <div class="ap-state-note ap-state-note--adopted">
            <Heart size={16} color="var(--rg-success)" filled />
            <div>
              <strong>{dict.profile.adoptedTitle}</strong>
              <p>{dict.profile.adoptedBody}</p>
            </div>
          </div>
        )
      }
      {
        deceased && (
          <div class="ap-state-note ap-state-note--memorial">
            <Heart size={16} color="var(--rg-primary-deep)" filled />
            <div>
              <strong>
                {dict.profile.memorialTitle}
                {lifespan && <span class="ap-memorial-years"> · {lifespan}</span>}
              </strong>
              <p>{dict.profile.memorialBody}</p>
            </div>
          </div>
        )
      }

      {
        (facts.length > 0 || feeUsd != null) && (
          <div class="ap-facts">
            <SectionLabel>{dict.profile.quickFacts}</SectionLabel>
            <dl>
              {facts.map((f) => (
                <div class="ap-fact">
                  <dt>{f.label}</dt>
                  <dd>{f.value}</dd>
                </div>
              ))}
              {feeUsd != null && (
                <div class="ap-fact">
                  <dt>{dict.profile.fee}</dt>
                  <dd>
                    <FxAmount usd={feeUsd} unavailable={dict.fx.unavailable} />
                  </dd>
                </div>
              )}
            </dl>
          </div>
        )
      }

      <div class="ap-cta">
        {
          isAvailable ? (
            <Button href={applyHref} variant="primary" size="lg" block>
              <Heart slot="icon" size={16} color="#fff" filled />
              {applyLabel}
            </Button>
          ) : isResident ? (
            <Button href="#sponsor" variant="primary" size="lg" block>
              <Heart slot="icon" size={16} color="#fff" filled />
              {dict.profile.sponsorTitle}
            </Button>
          ) : (
            <Button href={backHref} variant="primary" size="lg" block>
              <Icon slot="iconRight" name="arrow-right" />
              {backLabel}
            </Button>
          )
        }
        {
          isResident ? (
            <a
              class="ap-icon-btn"
              href={`mailto:ranchogasparsanctuary@gmail.com`}
              aria-label={dict.profile.save}
            >
              <Heart size={18} color="var(--rg-primary)" />
            </a>
          ) : (
            <button
              class="ap-icon-btn"
              type="button"
              aria-label={shareLabel}
              title={shareLabel}
              data-share-url={Astro.url.pathname}
              data-share-title={aboutHeading}
              data-share-text={d.summary ?? aboutHeading}
              data-share-copied={copiedLabel}
            >
              <span class="ap-share-icon ap-share-icon--share">
                <Icon name="share" size={18} />
              </span>
              <span class="ap-share-icon ap-share-icon--check">
                <Icon name="check" size={18} />
              </span>
              <span class="ap-share-feedback" aria-hidden="true">
                {copiedLabel}
              </span>
            </button>
          )
        }
      </div>

      {
        isAvailable && (
          <div class="ap-foster">
            <Heart size={16} color="var(--rg-primary-deep)" filled />
            <div>
              <strong>{dict.profile.fosterTitle}</strong>
              <p>{dict.profile.fosterBody}</p>
            </div>
          </div>
        )
      }
    </div>
  </div>

  <!-- Story + process / sponsor -->
  <div class:list={['ap-lower', !showSponsor && 'ap-lower--full']}>
    <div class="ap-story">
      <SectionLabel>{dict.profile.aboutEyebrow}</SectionLabel>
      <h2 class="ap-h2 rg-display">{aboutHeading}</h2>
      <div class="ap-prose">
        <Content />
      </div>

      {
        isAvailable && (
          <div class="ap-process">
            <SectionLabel>{dict.profile.processEyebrow}</SectionLabel>
            <h2 class="ap-h2 rg-display">{dict.profile.processHeading}</h2>
            <Accordion items={dict.profile.process} />
          </div>
        )
      }
    </div>

    {
      showSponsor && (
        <aside class="ap-aside" id="sponsor">
          <SectionLabel>{dict.profile.sponsorEyebrow}</SectionLabel>
          <h3 class="ap-aside-title rg-display">{dict.profile.sponsorTitle}</h3>
          <p class="ap-aside-body">{dict.profile.sponsorBody}</p>
          <DonationWidget lang={lang} compact amounts={[25, 50, 100, 200]} defaultAmount={50} />
        </aside>
      )
    }
  </div>

  <!-- Similar -->
  {
    similar.length > 0 && (
      <div class="ap-similar">
        <SectionLabel>{dict.profile.similarEyebrow}</SectionLabel>
        <h2 class="ap-h2 rg-display">{dict.profile.similarHeading}</h2>
        <div class="ap-similar-grid">
          {similar.map((e) => (
            <AnimalCard
              name={e.data.name}
              kind={e.data.species}
              sex={e.data.sex === 'unknown' ? undefined : e.data.sex}
              dob={e.data.dob}
              dobEstimated={e.data.dobEstimated}
              lang={lang}
              description={e.data.summary}
              status={e.data.status}
              statusLabel={
                e.data.status === 'adoptable' ? dict.status.adoptable : dict.status.resident
              }
              meetLabel={dict.adoptables.meet}
              tags={e.data.tags}
              href={localizePath(animalPath(e), lang)}
              image={e.data.cover}
              imageAlt={e.data.coverAlt}
            />
          ))}
        </div>
      </div>
    )
  }

  <p class="ap-back">
    <a href={backHref}>← {backLabel}</a>
  </p>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-share-url]').forEach((button) => {
    if (button.dataset.shareReady === 'true') return;
    button.dataset.shareReady = 'true';

    button.addEventListener('click', async () => {
      const url = new URL(button.dataset.shareUrl ?? '/', window.location.href).toString();
      const title = button.dataset.shareTitle ?? document.title;
      const text = button.dataset.shareText;
      const payload = { title, text, url };

      try {
        if (navigator.share) {
          await navigator.share(payload);
          return;
        }
        if (!navigator.clipboard) return;
        await navigator.clipboard.writeText(url);
        const originalLabel = button.getAttribute('aria-label') ?? title;
        const copiedLabel = button.dataset.shareCopied ?? 'Link copied';
        button.classList.add('is-copied');
        button.setAttribute('aria-label', copiedLabel);
        button.setAttribute('title', copiedLabel);
        window.setTimeout(() => {
          button.classList.remove('is-copied');
          button.setAttribute('aria-label', originalLabel);
          button.setAttribute('title', originalLabel);
        }, 1800);
      } catch {
        // User cancellation or unavailable clipboard: leave the page unchanged.
      }
    });
  });
</script>

<style>
  .ap-top {
    margin-top: 24px;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 36px;
  }
  /* Wrapper elements (which I control) enforce the crop ratio; the <Image>
     just fills them. Robust regardless of the width/height Astro emits. */
  .ap-hero {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 20px;
  }
  .ap-hero :global(.ap-hero-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ap-thumbs {
    margin-top: 12px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .ap-thumb {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px;
  }
  .ap-thumb :global(.ap-thumb-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ap-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .ap-name {
    font-size: 48px;
    margin: 0;
    line-height: 1.1;
  }
  .ap-name-heart {
    margin-left: 8px;
  }
  .ap-meta {
    margin: 6px 0 0;
    font-size: 16px;
    color: var(--rg-ink-soft);
  }
  .ap-resident-note {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 18px;
    padding: 14px 16px;
    background: var(--rg-primary-faint);
    border: 1px solid var(--rg-primary-soft);
    border-radius: 14px;
    font-size: 14px;
    font-weight: 700;
    color: var(--rg-primary-deep);
  }
  /* Adopted / in-memoriam callouts share the resident-note's shape but each get
     their own accent. */
  .ap-state-note {
    display: flex;
    gap: 12px;
    margin-top: 18px;
    padding: 14px 16px;
    border-radius: 14px;
    border: 1px solid var(--rg-primary-soft);
    background: var(--rg-primary-faint);
  }
  .ap-state-note strong {
    font-size: 14px;
    color: var(--rg-primary-deep);
  }
  .ap-state-note p {
    margin: 4px 0 0;
    font-size: 13px;
    color: var(--rg-ink-soft);
    line-height: 1.5;
  }
  .ap-state-note--adopted {
    border-color: #bfe3cd;
    background: #eef8f1;
  }
  .ap-state-note--adopted strong {
    color: var(--rg-success);
  }
  .ap-memorial-years {
    font-weight: 700;
    color: var(--rg-ink-soft);
  }
  .ap-facts {
    margin-top: 20px;
    background: var(--rg-surface);
    border: 1px solid var(--rg-border);
    border-radius: 16px;
    padding: 18px;
  }
  .ap-facts dl {
    margin: 10px 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    row-gap: 10px;
    column-gap: 16px;
  }
  .ap-fact {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    font-size: 13px;
  }
  .ap-fact dt {
    color: var(--rg-ink-soft);
  }
  .ap-fact dd {
    margin: 0;
    color: var(--rg-ink);
    font-weight: 700;
    text-align: right;
  }
  .ap-cta {
    margin-top: 20px;
    display: flex;
    gap: 10px;
    align-items: stretch;
  }
  .ap-icon-btn {
    position: relative;
    width: 52px;
    flex-shrink: 0;
    padding: 0;
    display: inline-grid;
    place-items: center;
    background: var(--rg-surface);
    border: 1.5px solid var(--rg-border);
    border-radius: 999px;
    appearance: none;
    color: var(--rg-primary);
    cursor: pointer;
  }
  .ap-icon-btn:hover,
  .ap-icon-btn.is-copied {
    background: var(--rg-primary-faint);
  }
  .ap-share-feedback {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    pointer-events: none;
    white-space: nowrap;
    border-radius: 999px;
    background: var(--rg-ink);
    color: #fff;
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
    opacity: 0;
    transform: translateY(-3px);
    transition:
      opacity 0.15s,
      transform 0.15s;
  }
  .ap-share-icon {
    display: inline-flex;
    grid-area: 1 / 1;
    transition:
      opacity 0.15s,
      transform 0.15s;
  }
  .ap-share-icon--check {
    opacity: 0;
    transform: scale(0.7);
  }
  .ap-icon-btn.is-copied .ap-share-icon--share {
    opacity: 0;
    transform: scale(0.7);
  }
  .ap-icon-btn.is-copied .ap-share-icon--check {
    opacity: 1;
    transform: scale(1);
  }
  .ap-icon-btn.is-copied .ap-share-feedback {
    opacity: 1;
    transform: translateY(0);
  }
  .ap-foster {
    margin-top: 16px;
    display: flex;
    gap: 12px;
    padding: 16px;
    background: var(--rg-primary-faint);
    border: 1px solid var(--rg-primary-soft);
    border-radius: 14px;
    color: var(--rg-primary-deep);
  }
  .ap-foster strong {
    font-size: 14px;
  }
  .ap-foster p {
    margin: 4px 0 0;
    font-size: 13px;
    color: var(--rg-ink-soft);
    line-height: 1.5;
  }
  .ap-lower {
    margin-top: 48px;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 32px;
    align-items: start;
  }
  /* No sponsor aside (adopted / in memoriam) — let the story use full width. */
  .ap-lower--full {
    grid-template-columns: 1fr;
  }
  .ap-h2 {
    font-size: 24px;
    margin: 4px 0 12px;
  }
  .ap-prose {
    font-size: 16px;
    color: var(--rg-ink-soft);
    line-height: 1.7;
  }
  .ap-prose :global(p) {
    margin: 0 0 16px;
  }
  .ap-process {
    margin-top: 28px;
  }
  .ap-aside {
    position: sticky;
    top: 88px;
  }
  .ap-aside-title {
    font-size: 22px;
    margin: 4px 0 6px;
  }
  .ap-aside-body {
    font-size: 14px;
    color: var(--rg-ink-soft);
    line-height: 1.55;
    margin: 0 0 16px;
  }
  .ap-similar {
    margin-top: 48px;
  }
  .ap-similar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 12px;
  }
  .ap-back {
    margin-top: 32px;
  }
  .ap-back a {
    font-weight: 700;
    color: var(--rg-primary-deep);
  }

  @media (max-width: 980px) {
    .ap-top,
    .ap-lower {
      grid-template-columns: 1fr;
    }
    .ap-name {
      font-size: 36px;
    }
    .ap-aside {
      position: static;
    }
    .ap-similar-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .ap-similar-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
