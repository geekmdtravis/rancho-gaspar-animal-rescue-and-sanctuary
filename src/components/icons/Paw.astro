---
interface Props {
  size?: number;
  color?: string;
  opacity?: number;
  class?: string;
}
const { size = 24, color = 'currentColor', opacity = 1, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={color}
  opacity={opacity}
  class={className}
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <ellipse cx="6" cy="9" rx="2" ry="2.6"></ellipse>
  <ellipse cx="11" cy="6" rx="2" ry="2.6"></ellipse>
  <ellipse cx="16" cy="9" rx="2" ry="2.6"></ellipse>
  <ellipse cx="19" cy="14" rx="1.8" ry="2.2"></ellipse>
  <path
    d="M12 12 C 8 12, 6 14, 6 17.5 C 6 21, 9 22, 12 22 C 15 22, 18 21, 18 17.5 C 18 14, 16 12, 12 12 Z"
  ></path>
</svg>
