---
// SiteFooter — multi-column footer with brand blurb, link columns, contact
// details, and a newsletter signup. Ported from components-blocks.jsx
// SiteFooter, with localized links.
import Logo from './Logo.astro';
import Button from './Button.astro';
import Icon from './icons/Icon.astro';
import Heart from './icons/Heart.astro';
import { t, localizePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = t(lang);
const year = new Date().getFullYear();

const quick = [
  { label: dict.footer.links.adopt, path: '/adopt' },
  { label: dict.footer.links.involved, path: '/get-involved' },
];
const about = [
  { label: dict.footer.links.story, path: '/about' },
  { label: dict.footer.links.residents, path: '/residents' },
  { label: dict.footer.links.stories, path: '/stories' },
  { label: dict.footer.links.contact, path: '/contact' },
];
const social = ['Instagram', 'Facebook', 'TikTok', 'YouTube'];
---

<footer class="foot">
  <div class="foot__cloud" aria-hidden="true">
    <svg
      width="400"
      height="240"
      viewBox="0 0 100 60"
      xmlns="http://www.w3.org/2000/svg"
      opacity="0.4"
    >
      <path
        d="M20 50 Q 5 50 5 38 Q 5 28 18 26 Q 18 14 32 14 Q 38 4 50 8 Q 60 2 70 12 Q 86 12 90 26 Q 99 28 95 42 Q 95 52 80 50 Z"
        fill="#fff"></path>
    </svg>
  </div>

  <div class="foot__grid">
    <div class="foot__brand">
      <Logo size="sm" tagline={dict.site.tagline} ariaLabel={dict.site.org} />
      <p class="foot__desc">{dict.site.description}</p>
    </div>

    <div>
      <div class="foot__title">{dict.footer.quickLinks}</div>
      <ul class="foot__list">
        {
          quick.map((l) => (
            <li>
              <a href={localizePath(l.path, lang)}>{l.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <div class="foot__title">{dict.footer.aboutCol}</div>
      <ul class="foot__list">
        {
          about.map((l) => (
            <li>
              <a href={localizePath(l.path, lang)}>{l.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <div class="foot__title">{dict.footer.contactCol}</div>
      <address class="foot__contact">
        <a href="mailto:ranchogasparsanctuary@gmail.com">
          <Icon name="mail" /> ranchogasparsanctuary@gmail.com
        </a>
        <span><Icon name="pin" /> Mendonça, SP · Brasil</span>
      </address>
      <div class="foot__social">
        {
          social.map((s) => (
            <span class="foot__social-dot" title={s} aria-label={s}>
              {s[0]}
            </span>
          ))
        }
      </div>
    </div>

    <div>
      <div class="foot__title">{dict.footer.stayConnected}</div>
      <p class="foot__stay">{dict.footer.stayBody}</p>
      <form class="foot__form" method="post">
        <label class="foot__sr" for="foot-email">{dict.newsletter.placeholder}</label>
        <input
          id="foot-email"
          type="email"
          name="email"
          placeholder={dict.newsletter.placeholder}
          required
        />
        <Button type="submit" size="sm" variant="primary">{dict.newsletter.cta}</Button>
      </form>
    </div>
  </div>

  <div class="foot__bar">
    <span>
      © {year}
      {dict.site.org} · {dict.footer.madeWith}
      <Heart size={11} color="var(--rg-primary)" filled />
      {dict.footer.inBrazil}
    </span>
    <span>{dict.footer.nonprofit}</span>
  </div>
</footer>

<style>
  .foot {
    background: var(--rg-primary-faint);
    padding: 56px 32px 28px;
    border-top: 1px solid var(--rg-primary-soft);
    position: relative;
    overflow: hidden;
    font-family: var(--rg-font-body);
  }
  .foot__cloud {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.6;
    pointer-events: none;
  }
  .foot__grid {
    max-width: var(--rg-maxw);
    margin: 0 auto;
    position: relative;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr 1.2fr;
    gap: 32px;
  }
  .foot__desc {
    margin-top: 16px;
    font-size: 13px;
    color: var(--rg-ink-soft);
    line-height: 1.6;
    max-width: 240px;
  }
  .foot__title {
    font-size: 13px;
    font-weight: 700;
    color: var(--rg-ink);
    margin-bottom: 12px;
  }
  .foot__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .foot__list a {
    font-size: 13px;
    color: var(--rg-ink-soft);
  }
  .foot__list a:hover {
    color: var(--rg-primary-deep);
  }
  .foot__contact {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
    color: var(--rg-ink-soft);
  }
  .foot__contact {
    font-style: normal;
  }
  .foot__contact a,
  .foot__contact span {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--rg-ink-soft);
  }
  .foot__contact a:hover {
    color: var(--rg-primary-deep);
  }
  .foot__social {
    display: flex;
    gap: 8px;
    margin-top: 16px;
  }
  .foot__social-dot {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    background: var(--rg-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--rg-primary-deep);
    font-size: 11px;
    font-weight: 700;
  }
  .foot__stay {
    font-size: 13px;
    color: var(--rg-ink-soft);
    margin: 0 0 12px;
  }
  .foot__form {
    display: flex;
    gap: 6px;
  }
  .foot__form input {
    flex: 1;
    min-width: 0;
    padding: 10px 12px;
    border: 1.5px solid var(--rg-border);
    background: var(--rg-surface);
    border-radius: 999px;
    font-family: inherit;
    font-size: 13px;
    outline: none;
  }
  .foot__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
  .foot__bar {
    max-width: var(--rg-maxw);
    margin: 40px auto 0;
    padding: 20px 0 0;
    border-top: 1px solid var(--rg-primary-soft);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--rg-ink-mute);
  }
  .foot__bar span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  @media (max-width: 980px) {
    .foot__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .foot__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
