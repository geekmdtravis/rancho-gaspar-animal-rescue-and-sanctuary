---
// BlurImage — wraps Astro's <Image> with an inlined low-res (LQIP) preview.
// The preview is a 24px-wide WebP, base64-inlined and rendered as a blurred
// CSS background on the wrapper. The user sees a soft, color-correct shape
// immediately; once the responsive <img> finishes downloading, it covers the
// LQIP. No JavaScript — pure CSS layering.
//
// Forwards `wrapperClass` and `imgClass` so existing call-site CSS hooks
// (e.g. `.acard__imgwrap`, `.acard__img`) keep targeting the same elements.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { lqipDataUrl } from '../lib/lqip';

interface Props {
  src: ImageMetadata;
  alt: string;
  widths: number[];
  sizes: string;
  quality?: number;
  /** Override Astro's default lazy loading — set "eager" for above-the-fold. */
  loading?: 'lazy' | 'eager';
  /** Pair with loading="eager" on the LCP image to signal high priority. */
  fetchpriority?: 'auto' | 'high' | 'low';
  /** CSS aspect-ratio string for the wrapper, e.g. "1 / 1", "4 / 3". */
  ratio: string;
  /** Border-radius in px applied to the wrapper. */
  radius?: number;
  /** Class on the outer wrapper; preserved for existing CSS hooks. */
  wrapperClass?: string;
  /** Class on the inner <img>; preserved for existing CSS hooks. */
  imgClass?: string;
}

const {
  src,
  alt,
  widths,
  sizes,
  quality,
  loading,
  fetchpriority,
  ratio,
  radius,
  wrapperClass,
  imgClass,
} = Astro.props;

const lqip = await lqipDataUrl(src);
// fetchpriority isn't in Astro's ImgHTMLAttributes type yet; spread it
// conditionally so we don't trip astro check.
const extraAttrs: Record<string, string> = fetchpriority ? { fetchpriority } : {};
---

<span
  class:list={['blur-img', wrapperClass]}
  style={{
    aspectRatio: ratio,
    borderRadius: radius != null ? `${radius}px` : undefined,
    // The custom property feeds the ::before below. When generation failed
    // we set `none` so the pseudo just shows the neutral fallback fill.
    '--rg-lqip': lqip ? `url("${lqip}")` : 'none',
  }}
>
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    quality={quality}
    loading={loading}
    class:list={['blur-img__img', imgClass]}
    {...extraAttrs}
  />
</span>

<style>
  .blur-img {
    position: relative;
    display: block;
    overflow: hidden;
    /* Neutral fallback for the rare case LQIP generation failed. */
    background: var(--rg-surface-alt, #f3eee9);
  }
  /* The LQIP layer. blur(12px) softens the 24px source into a gaussian; the
     1.15× scale hides the transparent halo blur() introduces at the edges
     (clipped by the wrapper's overflow:hidden). */
  .blur-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--rg-lqip);
    background-size: cover;
    background-position: center;
    filter: blur(12px);
    transform: scale(1.15);
  }
  /* The responsive image sits above the LQIP. position:relative is what puts
     it on a layer above the ::before. :global() is needed because the
     <Image> component scope doesn't match this stylesheet's. */
  .blur-img :global(.blur-img__img) {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
