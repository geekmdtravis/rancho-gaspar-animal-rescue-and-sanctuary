---
// HomeSections — the full home page body, shared by the EN and PT-BR routes.
// Adoptable animals are pulled live from the content collection for the active
// locale (featured first), so editing in Sveltia updates the home page.
import { getCollection } from 'astro:content';
import Hero from './Hero.astro';
import SectionLabel from './SectionLabel.astro';
import Button from './Button.astro';
import DonationWidget from './DonationWidget.astro';
import AnimalCard from './AnimalCard.astro';
import StatBlock from './StatBlock.astro';
import GetInvolvedCard from './GetInvolvedCard.astro';
import TestimonialCard from './TestimonialCard.astro';
import NewsletterBlock from './NewsletterBlock.astro';
import Heart from './icons/Heart.astro';
import Paw from './icons/Paw.astro';
import Icon from './icons/Icon.astro';
import { t, localizePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = t(lang);

const all = await getCollection('animals');
const adoptables = all
  .filter((e) => e.id.startsWith(`${lang}/`) && e.data.status === 'adoptable')
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured) || a.data.order - b.data.order)
  .slice(0, 4)
  .map((e) => ({ slug: e.id.split('/')[1], data: e.data }));

const involvedAccents = ['sage', 'sky', 'lilac'] as const;
const involvedPaths = ['/get-involved#volunteer', '/get-involved#foster', '/get-involved#share'];
const testimonialKinds = ['dog', 'cat'] as const;
const adoptHref = localizePath('/adopt', lang);
const donateHref = localizePath('/donate', lang);
const volunteerHref = localizePath('/get-involved', lang);
---

<!-- Hero -->
<section class="rg-container hp-hero">
  <Hero lang={lang} adoptHref={adoptHref} donateHref={donateHref} volunteerHref={volunteerHref} />
</section>

<!-- Adoptables intro + donation widget -->
<section class="rg-container rg-section--tight">
  <div class="hp-split">
    <div>
      <div class="hp-label-row">
        <SectionLabel>{dict.adoptables.label}</SectionLabel>
        <Heart size={14} color="var(--rg-primary)" filled />
      </div>
      <h2 class="hp-h2">{dict.adoptables.title}</h2>
      <p class="hp-lead">{dict.adoptables.body}</p>
      <div class="hp-cta-row">
        <Button href={adoptHref} variant="primary">
          {dict.adoptables.viewAll}<Icon slot="iconRight" name="arrow-right" />
        </Button>
        <Button href={adoptHref} variant="ghost">{dict.adoptables.saveFavorites}</Button>
      </div>
    </div>
    <DonationWidget lang={lang} compact donateUrl={donateHref} />
  </div>

  {
    adoptables.length > 0 ? (
      <div class="hp-grid hp-grid--4">
        {adoptables.map((a) => (
          <AnimalCard
            name={a.data.name}
            kind={a.data.species}
            sex={a.data.sex === 'unknown' ? undefined : a.data.sex}
            age={a.data.age}
            description={a.data.summary}
            status={a.data.status}
            statusLabel={dict.status.adoptable}
            meetLabel={dict.adoptables.meet}
            tags={a.data.tags}
            href={localizePath(`/adopt/${a.slug}`, lang)}
            image={a.data.cover}
            imageAlt={a.data.coverAlt}
          />
        ))}
      </div>
    ) : (
      <p class="hp-empty">{dict.adoptables.empty}</p>
    )
  }
</section>

<!-- Impact -->
<section class="rg-container rg-section">
  <div class="hp-impact">
    <div class="hp-center">
      <SectionLabel>{dict.impact.label}</SectionLabel>
      <h2 class="hp-h2">{dict.impact.title}</h2>
      <p class="hp-lead hp-lead--center">{dict.impact.body}</p>
    </div>
    <div class="hp-grid hp-grid--4 hp-stats">
      {
        dict.impact.stats.map((s, i) => (
          <StatBlock value={s.value} label={s.label} sub={s.sub}>
            {i === 0 && <Paw slot="icon" size={22} color="currentColor" />}
            {i === 1 && <Heart slot="icon" size={22} color="currentColor" filled />}
            {i === 2 && <Icon slot="icon" name="gift" size={22} />}
            {i === 3 && <Icon slot="icon" name="users" size={22} />}
          </StatBlock>
        ))
      }
    </div>
  </div>
</section>

<!-- Get involved -->
<section class="rg-container rg-section">
  <div class="hp-center hp-center--mb">
    <SectionLabel>{dict.involved.label}</SectionLabel>
    <h2 class="hp-h2">{dict.involved.title}</h2>
  </div>
  <div class="hp-grid hp-grid--3">
    {
      dict.involved.cards.map((c, i) => (
        <GetInvolvedCard
          title={c.title}
          description={c.desc}
          cta={c.cta}
          href={localizePath(involvedPaths[i], lang)}
          accent={involvedAccents[i]}
        >
          {i === 0 && <Icon slot="icon" name="hand" size={32} />}
          {i === 1 && <Icon slot="icon" name="home" size={32} />}
          {i === 2 && <Icon slot="icon" name="share" size={32} />}
        </GetInvolvedCard>
      ))
    }
  </div>
</section>

<!-- Testimonials -->
<section class="rg-container rg-section">
  <div class="hp-grid hp-grid--2">
    {
      dict.testimonials.map((tm, i) => (
        <TestimonialCard
          quote={tm.quote}
          author={tm.author}
          role={tm.role}
          kind={testimonialKinds[i]}
        />
      ))
    }
  </div>
</section>

<!-- Newsletter -->
<section class="rg-container rg-section">
  <NewsletterBlock lang={lang} />
</section>

<style>
  .hp-hero {
    padding-block: 32px;
  }
  .hp-split {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 32px;
    align-items: center;
    margin-bottom: 28px;
  }
  .hp-label-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
  }
  .hp-label-row :global(.rg-section-label) {
    margin: 0;
  }
  .hp-h2 {
    font-family: var(--rg-font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 32px;
    letter-spacing: -0.5px;
    color: var(--rg-ink);
    margin: 4px 0 8px;
  }
  .hp-lead {
    font-size: 16px;
    color: var(--rg-ink-soft);
    margin: 0;
    max-width: 480px;
    line-height: 1.55;
  }
  .hp-lead--center {
    margin-inline: auto;
    max-width: 540px;
  }
  .hp-cta-row {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .hp-grid {
    display: grid;
    gap: 16px;
  }
  .hp-grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  .hp-grid--3 {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .hp-grid--2 {
    grid-template-columns: 1fr 1fr;
  }
  .hp-empty {
    text-align: center;
    color: var(--rg-ink-soft);
    padding: 40px;
    background: var(--rg-surface);
    border: 1px dashed var(--rg-border-strong);
    border-radius: 18px;
  }
  .hp-impact {
    background: var(--rg-primary-faint);
    border-radius: 24px;
    padding: 48px 40px;
  }
  .hp-stats {
    gap: 24px;
  }
  .hp-center {
    text-align: center;
  }
  .hp-center--mb {
    margin-bottom: 32px;
  }
  .hp-center .hp-h2 {
    margin-top: 4px;
  }

  @media (max-width: 980px) {
    .hp-split {
      grid-template-columns: 1fr;
    }
    .hp-grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
    .hp-grid--3,
    .hp-grid--2 {
      grid-template-columns: 1fr;
    }
    .hp-impact {
      padding: 32px 20px;
    }
  }
  @media (max-width: 520px) {
    .hp-grid--4 {
      grid-template-columns: 1fr;
    }
  }
</style>
