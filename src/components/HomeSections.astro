---
// HomeSections — the full home page body, shared by the EN and PT-BR routes.
// Adoptable animals are pulled live from the content collection for the active
// locale (featured first), so editing in Sveltia updates the home page.
import { getCollection } from 'astro:content';
import Hero from './Hero.astro';
import SectionLabel from './SectionLabel.astro';
import Button from './Button.astro';
import DonationWidget from './DonationWidget.astro';
import AnimalCard from './AnimalCard.astro';
import GetInvolvedCard from './GetInvolvedCard.astro';
import TestimonialCard from './TestimonialCard.astro';
import NewsletterBlock from './NewsletterBlock.astro';
import Heart from './icons/Heart.astro';
import Icon from './icons/Icon.astro';
import { listReviews, findReview, isTranslated, reviewSlug } from '../lib/reviews';
import { t, localizePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = t(lang);

const all = await getCollection('animals');
const adoptables = all
  .filter(
    (e) =>
      e.id.startsWith(`${lang}/`) &&
      e.data.status === 'adoptable' &&
      // Don't feature animals already adopted or who have passed away.
      !e.data.adopted &&
      e.data.dod == null,
  )
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured) || a.data.order - b.data.order)
  .slice(0, 4)
  .map((e) => ({ slug: e.id.split('/')[1], data: e.data }));

// For translated reviews, also pull the origin-language version so the card can
// offer a "read original" toggle.
const reviewCards = await Promise.all(
  (await listReviews(lang)).map(async (r) => {
    const original = isTranslated(r, lang)
      ? await findReview(r.data.originLang, reviewSlug(r))
      : undefined;
    return { r, original };
  }),
);
const adoptHref = localizePath('/adopt', lang);
const donateHref = localizePath('/donate', lang);
const volunteerHref = localizePath('/get-involved', lang);
const getInvolvedEmailSubject = lang === 'pt-br' ? 'Participar' : 'Getting involved';
const getInvolvedEmailHref = `mailto:ranchogasparsanctuary@gmail.com?subject=${encodeURIComponent(
  getInvolvedEmailSubject,
)}`;
---

<!-- Hero -->
<section class="rg-container hp-hero">
  <Hero lang={lang} adoptHref={adoptHref} donateHref={donateHref} volunteerHref={volunteerHref} />
</section>

<!--
  Why this work is different. Sits between the hero and adoptables so a
  first-time visitor sees the stakes (no shelter, no clinic, no network in
  the rural Brazilian interior) before they meet the animals. Intentionally
  visually quiet — no icons, no card chrome — so it reads as a factual aside
  rather than a marketing block.
-->
<section class="rg-container rg-section--tight hp-safety">
  <div class="hp-safety-head">
    <SectionLabel>{dict.safetyNet.label}</SectionLabel>
    <h2 class="hp-safety-title">{dict.safetyNet.title}</h2>
    <p class="hp-safety-intro">{dict.safetyNet.intro}</p>
  </div>
  <ul class="hp-safety-gaps">
    {
      dict.safetyNet.gaps.map((g) => (
        <li class="hp-safety-gap">
          <div class="hp-safety-gap__title">{g.title}</div>
          <div class="hp-safety-gap__desc">{g.desc}</div>
        </li>
      ))
    }
  </ul>
  <p class="hp-safety-close">{dict.safetyNet.close}</p>
</section>

<!-- Adoptables intro + donation widget -->
<section class="rg-container rg-section--tight">
  <div class="hp-split">
    <div>
      <div class="hp-label-row">
        <SectionLabel>{dict.adoptables.label}</SectionLabel>
        <Heart size={14} color="var(--rg-primary)" filled />
      </div>
      <h2 class="hp-h2">{dict.adoptables.title}</h2>
      <p class="hp-lead">{dict.adoptables.body}</p>
      <div class="hp-cta-row">
        <Button href={adoptHref} variant="primary">
          {dict.adoptables.viewAll}<Icon slot="iconRight" name="arrow-right" />
        </Button>
      </div>
    </div>
    <DonationWidget lang={lang} compact donateUrl={donateHref} />
  </div>

  {
    adoptables.length > 0 ? (
      <div class="hp-grid hp-grid--4">
        {adoptables.map((a) => (
          <AnimalCard
            name={a.data.name}
            kind={a.data.species}
            sex={a.data.sex === 'unknown' ? undefined : a.data.sex}
            dob={a.data.dob}
            dobEstimated={a.data.dobEstimated}
            lang={lang}
            description={a.data.summary}
            status={a.data.status}
            statusLabel={dict.status.adoptable}
            meetLabel={dict.adoptables.meet}
            tags={a.data.tags}
            href={localizePath(`/adopt/${a.slug}`, lang)}
            image={a.data.cover}
            imageAlt={a.data.coverAlt}
          />
        ))}
      </div>
    ) : (
      <p class="hp-empty">{dict.adoptables.empty}</p>
    )
  }
</section>

<!-- Get involved -->
<section class="rg-container rg-section">
  <div class="hp-center hp-center--mb">
    <SectionLabel>{dict.involved.label}</SectionLabel>
  </div>
  <div class="hp-involved-simple">
    <GetInvolvedCard
      title={dict.involved.title}
      description={dict.involved.body}
      cta={dict.involved.cta}
      href={getInvolvedEmailHref}
      accent="pink"
      ctaIcon="mail"
    >
      <Icon slot="icon" name="mail" size={32} />
    </GetInvolvedCard>
  </div>
</section>

<!-- Testimonials -->
<section class="rg-container rg-section">
  <div class="hp-grid hp-grid--2">
    {
      reviewCards.map(({ r, original }) => (
        <TestimonialCard
          quote={r.data.quote}
          author={r.data.author}
          role={r.data.role}
          rating={r.data.rating}
          kind={r.data.kind}
          translatedFrom={
            original
              ? dict.reviews.translatedFrom.replace(
                  '{lang}',
                  dict.reviews.langNames[r.data.originLang],
                )
              : undefined
          }
          original={
            original
              ? {
                  quote: original.data.quote,
                  author: original.data.author,
                  role: original.data.role,
                }
              : undefined
          }
          showOriginalLabel={dict.reviews.showOriginal}
          showTranslationLabel={dict.reviews.showTranslation}
        />
      ))
    }
  </div>
</section>

<!-- Newsletter -->
<section class="rg-container rg-section">
  <NewsletterBlock lang={lang} />
</section>

<style>
  .hp-hero {
    padding-block: 32px;
  }
  .hp-split {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 32px;
    align-items: center;
    margin-bottom: 28px;
  }
  .hp-label-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
  }
  .hp-label-row :global(.rg-section-label) {
    margin: 0;
  }
  .hp-h2 {
    font-family: var(--rg-font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 32px;
    letter-spacing: -0.5px;
    color: var(--rg-ink);
    margin: 4px 0 8px;
  }
  .hp-lead {
    font-size: 16px;
    color: var(--rg-ink-soft);
    margin: 0;
    max-width: 480px;
    line-height: 1.55;
  }
  .hp-lead--center {
    margin-inline: auto;
    max-width: 540px;
  }
  .hp-cta-row {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .hp-grid {
    display: grid;
    gap: 16px;
  }
  .hp-grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  .hp-grid--3 {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .hp-grid--2 {
    grid-template-columns: 1fr 1fr;
  }
  .hp-empty {
    text-align: center;
    color: var(--rg-ink-soft);
    padding: 40px;
    background: var(--rg-surface);
    border: 1px dashed var(--rg-border-strong);
    border-radius: 18px;
  }
  .hp-center {
    text-align: center;
  }
  .hp-center--mb {
    margin-bottom: 32px;
  }
  .hp-center .hp-h2 {
    margin-top: 4px;
  }
  .hp-involved-simple {
    max-width: 560px;
    margin: 0 auto;
  }

  /* "We are the safety net" — homepage context section.
     Centered head, 3-column gap grid, single-sentence close in brand pink. */
  .hp-safety-head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 28px;
  }
  .hp-safety-title {
    font-family: var(--rg-font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 32px;
    letter-spacing: -0.5px;
    color: var(--rg-ink);
    margin: 4px 0 12px;
  }
  .hp-safety-intro {
    font-size: 16px;
    color: var(--rg-ink-soft);
    line-height: 1.55;
    margin: 0;
  }
  .hp-safety-gaps {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .hp-safety-gap {
    /* Pink left-rule rather than a card frame — quieter visual weight,
       reads as an aside instead of a feature grid. */
    padding: 4px 0 4px 16px;
    border-left: 3px solid var(--rg-primary);
  }
  .hp-safety-gap__title {
    font-family: var(--rg-font-body);
    font-weight: 700;
    font-size: 15px;
    color: var(--rg-ink);
    margin-bottom: 4px;
  }
  .hp-safety-gap__desc {
    font-size: 14px;
    color: var(--rg-ink-soft);
    line-height: 1.5;
  }
  .hp-safety-close {
    text-align: center;
    font-family: var(--rg-font-accent);
    font-size: 18px;
    color: var(--rg-primary);
    margin: 0;
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .hp-split {
      grid-template-columns: 1fr;
    }
    .hp-grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
    .hp-grid--3,
    .hp-grid--2 {
      grid-template-columns: 1fr;
    }
    .hp-safety-gaps {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .hp-grid--4 {
      grid-template-columns: 1fr;
    }
  }
</style>
