---
// NavHeader — sticky top bar with logo, primary nav, language switcher, and a
// Donate CTA. Collapses to a toggle menu on small screens. Ported/adapted from
// components-blocks.jsx NavHeader.
import Logo from './Logo.astro';
import Button from './Button.astro';
import Heart from './icons/Heart.astro';
import Icon from './icons/Icon.astro';
import { t, localizePath, stripLocale, languages, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  active?: string;
}
const { lang, active } = Astro.props;
const dict = t(lang);

const links = [
  { id: 'adopt', label: dict.nav.adopt, path: '/adopt' },
  { id: 'residents', label: dict.nav.residents, path: '/residents' },
  { id: 'involved', label: dict.nav.involved, path: '/get-involved' },
  { id: 'about', label: dict.nav.about, path: '/about' },
];

// Language switcher: same page, other locale.
const basePath = stripLocale(Astro.url.pathname);
const otherLang: Lang = lang === 'en' ? 'pt-br' : 'en';
const switchHref = localizePath(basePath, otherLang);
---

<header class="nav">
  <div class="nav__inner">
    <Logo
      href={localizePath('/', lang)}
      size="sm"
      tagline={dict.site.tagline}
      ariaLabel={dict.site.org}
    />

    <button
      type="button"
      class="nav__burger"
      aria-expanded="false"
      aria-controls="nav-links"
      aria-label={dict.nav.openMenu}
      data-nav-toggle
    >
      <span></span><span></span><span></span>
    </button>

    <nav id="nav-links" class="nav__links" aria-label={dict.site.org}>
      {
        links.map((l) => (
          <a
            href={localizePath(l.path, lang)}
            class:list={['nav__link', active === l.id && 'is-active']}
            aria-current={active === l.id ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <div class="nav__actions">
        <a class="nav__lang" href={switchHref} hreflang={otherLang} aria-label={dict.nav.language}>
          <Icon name="globe" size={15} />
          {languages[otherLang].split(' ')[0]}
        </a>
        <Button href={localizePath('/donate', lang)} variant="primary">
          <Heart slot="icon" size={14} color="#fff" filled />
          {dict.nav.donate}
        </Button>
      </div>
    </nav>
  </div>
</header>

<script>
  // The switcher href is built at static build time from the pathname only, so
  // it can't know about runtime query params. Carry the live search + hash over
  // on switch — the donate page forwards `?freq=&amount=` and the chosen gift
  // should survive a language change.
  const langLink = document.querySelector<HTMLAnchorElement>('.nav__lang');
  if (langLink && (location.search || location.hash)) {
    langLink.href += location.search + location.hash;
  }

  // Mobile menu: a real button driven by aria-expanded. Previously this was a
  // CSS-checkbox-hack (`<input type=checkbox>` + `<label>`), which is invisible
  // to the keyboard — the input was display:none and labels aren't focusable.
  // A button is focusable, responds to Enter/Space, and exposes the open state
  // to assistive tech via aria-expanded.
  const burger = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const navLinks = document.getElementById('nav-links');
  if (burger && navLinks) {
    const setOpen = (open: boolean) => {
      burger.setAttribute('aria-expanded', String(open));
    };
    burger.addEventListener('click', () => {
      setOpen(burger.getAttribute('aria-expanded') !== 'true');
    });
    // Close on Escape from anywhere inside the nav (focus might be on a link).
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        burger.focus();
      }
    });
    // Tapping a nav link should close the menu so the next page doesn't load
    // with the panel stuck open if back-navigation restores this DOM.
    navLinks
      .querySelectorAll('a')
      .forEach((a) => a.addEventListener('click', () => setOpen(false)));
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--rg-surface) 88%, transparent);
    border-bottom: 1px solid var(--rg-border);
    backdrop-filter: blur(8px);
  }
  .nav__inner {
    max-width: var(--rg-maxw);
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav__burger {
    display: none;
    /* Reset native <button> chrome — the burger is a focusable button now,
       not a styled <label>, so we override the UA defaults explicitly. */
    border: none;
    background: transparent;
    color: inherit;
    font: inherit;
  }
  .nav__burger:focus-visible {
    outline: 2px solid var(--rg-primary);
    outline-offset: 2px;
    border-radius: 6px;
  }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }
  .nav__link {
    padding: 8px 14px;
    border-radius: 999px;
    color: var(--rg-ink);
    font-size: 14px;
    font-weight: 600;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .nav__link:hover {
    background: var(--rg-primary-faint);
  }
  .nav__link.is-active {
    color: var(--rg-primary);
    background: var(--rg-primary-faint);
  }
  .nav__actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }
  .nav__lang {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 12px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    color: var(--rg-ink-soft);
    border: 1.5px solid var(--rg-border);
  }
  .nav__lang:hover {
    background: var(--rg-primary-faint);
    color: var(--rg-primary-deep);
  }

  @media (max-width: 980px) {
    .nav__inner {
      padding: 12px 20px;
      flex-wrap: wrap;
    }
    .nav__burger {
      display: inline-flex;
      flex-direction: column;
      gap: 4px;
      margin-left: auto;
      padding: 8px;
      cursor: pointer;
    }
    .nav__burger span {
      width: 22px;
      height: 2px;
      background: var(--rg-ink);
      border-radius: 2px;
      transition:
        transform 0.2s,
        opacity 0.2s;
    }
    .nav__links {
      display: none;
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      gap: 4px;
      padding-top: 12px;
    }
    /* Burger uses aria-expanded as the open-state hook — that's what assistive
       tech reads, and it's what the JS toggles, so we drive CSS off the same
       attribute (no extra class to keep in sync). */
    .nav__burger[aria-expanded='true'] ~ .nav__links {
      display: flex;
    }
    .nav__burger[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }
    .nav__burger[aria-expanded='true'] span:nth-child(2) {
      opacity: 0;
    }
    .nav__burger[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }
    .nav__link {
      padding: 12px 14px;
    }
    .nav__actions {
      margin: 8px 0 0;
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
