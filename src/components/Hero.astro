---
// Hero — the home page banner. Ported from components-blocks.jsx HeroBlock:
// copy + CTAs on the left, a real sanctuary cat photo clipped to a heart
// shape in the middle, and a "Rescue / Heal / Love" pillar card on the right.
// The middle column used to render an illustrated dog+cat inside an outlined
// heart; using a real photo here makes the first impression specifically
// about *our* animals, not generic pet iconography.
import Confetti from './Confetti.astro';
import Badge from './Badge.astro';
import Button from './Button.astro';
import Heart from './icons/Heart.astro';
import Paw from './icons/Paw.astro';
import Icon from './icons/Icon.astro';
import Avatar from './Avatar.astro';
import BlurImage from './BlurImage.astro';
import heroPhoto from '../assets/uploads/bruxa-shy.jpeg';
import { listAnimals } from '../lib/animals';
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  adoptHref: string;
  donateHref: string;
  volunteerHref: string;
}
const { lang, adoptHref, donateHref, volunteerHref } = Astro.props;
const h = t(lang).hero;
const avatarKinds = ['dog', 'cat', 'bunny'] as const;
// "Animals rescued" is a cumulative count of every animal we have a record
// for — adoptables, residents, adopted-out, and memorials all count. Pull
// from the content collection so the homepage never lies about the tally.
const rescuedCount = (await listAnimals(lang)).length;
---

<section class="hero">
  <Confetti density="high" />
  <div class="hero__grid">
    <div class="hero__copy">
      <Badge variant="soft" size="md">
        <Heart slot="icon" size={11} color="var(--rg-primary)" filled />
        {h.eyebrow}
      </Badge>
      <h1 class="hero__title">
        {h.titleLine1}<br />
        <span class="hero__emph">{h.titleEmphasis}</span>
        <span class="hero__title-heart"><Heart size={28} color="var(--rg-primary)" filled /></span>
      </h1>
      <p class="hero__body">{h.body}</p>
      <div class="hero__ctas">
        <Button href={adoptHref} size="lg" variant="primary"
          ><Paw slot="icon" size={16} color="#fff" />{h.ctaAdopt}</Button
        >
        <Button href={donateHref} size="lg" variant="secondary"
          ><Heart slot="icon" size={16} color="var(--rg-primary-deep)" filled />{
            h.ctaDonate
          }</Button
        >
        <Button href={volunteerHref} size="lg" variant="outline">{h.ctaVolunteer}</Button>
      </div>
      <div class="hero__social">
        <div class="hero__avatars">
          {
            avatarKinds.map((k) => (
              <span class="hero__avatar">
                <Avatar kind={k} size={36} />
              </span>
            ))
          }
        </div>
        <div class="hero__social-text">
          <strong>{rescuedCount} {h.statValue}</strong><br />{h.statSub}
        </div>
      </div>
    </div>

    <div class="hero__art">
      {
        /*
        Heart silhouette as a 6-segment cubic Bézier path. Each side uses
        three segments — bottom → outer "shoulder" → lobe peak → cleft —
        with tangent continuity tuned at every junction so the lobes read
        as round humps rather than pointed peaks:
          • outer shoulder (20, 180) / (380, 180): tangent is vertical
            (control points sit directly above/below the junction).
          • lobe peak (110, 50) / (290, 50): tangent is *horizontal*
            (control points sit directly left/right of the peak). This is
            the property that makes the top of each lobe round.
          • cleft (200, 130): tangent reverses 180° (both adjoining
            control points sit directly above at (200, 95)), producing
            the deep notch a natural heart has.
          • bottom point (200, 355): tangents meet at a shallow angle,
            giving a gently pointed base rather than a smooth dome.

        The clipPath uses `objectBoundingBox` units (normalized 0..1) so the
        same path masks an HTML element of any size, as long as its
        bounding box matches the heart's intrinsic 400×380 aspect ratio —
        enforced by `aspect-ratio: 400 / 380` on `.hero__art` below.
        Coordinates are the user-space path (see the outline SVG further
        down) divided by (400, 380); keep them in lockstep when tweaking.
      */
      }
      <svg class="hero__art-defs" aria-hidden="true" focusable="false">
        <defs>
          <clipPath id="hero-heart" clipPathUnits="objectBoundingBox">
            <path
              d="M 0.5 0.9342 C 0.225 0.8421 0.05 0.6316 0.05 0.4737 C 0.05 0.2763 0.1375 0.1316 0.275 0.1316 C 0.4 0.1316 0.5 0.2368 0.5 0.3421 C 0.5 0.2368 0.6 0.1316 0.725 0.1316 C 0.8625 0.1316 0.95 0.2763 0.95 0.4737 C 0.95 0.6316 0.775 0.8421 0.5 0.9342 Z"
            ></path>
          </clipPath>
        </defs>
      </svg>
      <BlurImage
        src={heroPhoto}
        alt={h.photoAlt}
        widths={[400, 600, 900]}
        sizes="(max-width: 980px) 92vw, 440px"
        quality={82}
        ratio="400 / 380"
        loading="eager"
        fetchpriority="high"
        wrapperClass="hero__art-photo"
        imgClass="hero__art-photo-img"
      />
      {
        /*
        Brand-pink stroke outline drawn over the clipped photo. The path
        matches the clipPath exactly; SVG strokes center on the path, so half
        the 3px width sits on top of the photo edge and half extends beyond,
        giving a clean ~1.5px rim without a visible gap.
      */
      }
      <svg
        class="hero__art-outline"
        viewBox="0 0 400 380"
        aria-hidden="true"
        focusable="false"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M 200 355 C 90 320 20 240 20 180 C 20 105 55 50 110 50 C 160 50 200 90 200 130 C 200 90 240 50 290 50 C 345 50 380 105 380 180 C 380 240 310 320 200 355 Z"
          stroke="var(--rg-primary)"
          stroke-width="3"
          fill="none"
          stroke-linejoin="round"
          vector-effect="non-scaling-stroke"></path>
      </svg>
    </div>

    <div class="hero__pillars">
      {
        h.pillars.map((p, i) => (
          <div class="hero__pillar">
            <div
              class="hero__pillar-icon"
              style={{
                background:
                  i === 1
                    ? '#D5E8F2'
                    : i === 0
                      ? 'var(--rg-primary-soft)'
                      : 'var(--rg-primary-faint)',
                color: i === 1 ? 'var(--rg-accent-sky)' : 'var(--rg-primary)',
              }}
            >
              {i === 0 && <Paw size={16} color="var(--rg-primary)" />}
              {i === 1 && <Heart size={16} color="var(--rg-accent-sky)" filled />}
              {i === 2 && <Icon name="home" size={16} />}
            </div>
            <div>
              <div class="hero__pillar-label">{p.label}</div>
              <div class="hero__pillar-desc">{p.desc}</div>
            </div>
          </div>
        ))
      }
      <div class="hero__pillar-footer">
        {h.pillarFooter}
        <Heart size={14} color="var(--rg-primary)" filled />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--rg-primary-faint);
    padding: 56px 40px;
    border-radius: 24px;
    position: relative;
    overflow: hidden;
    font-family: var(--rg-font-body);
  }
  .hero__grid {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 1fr 0.7fr;
    gap: 36px;
    align-items: center;
  }
  .hero__title {
    margin: 16px 0 0;
    font-family: var(--rg-font-display);
    font-size: 56px;
    font-weight: 600;
    line-height: 1.05;
    color: var(--rg-ink);
    letter-spacing: -0.5px;
    font-style: italic;
  }
  .hero__emph {
    color: var(--rg-primary);
  }
  .hero__title-heart {
    display: inline-block;
    margin-left: 12px;
  }
  .hero__body {
    margin: 16px 0 24px;
    font-size: 17px;
    color: var(--rg-ink-soft);
    line-height: 1.55;
    max-width: 440px;
    font-style: normal;
  }
  .hero__ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .hero__social {
    margin-top: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero__avatars {
    display: flex;
  }
  .hero__avatar {
    border: 3px solid var(--rg-primary-faint);
    border-radius: 999px;
    background: var(--rg-surface);
    display: inline-flex;
  }
  .hero__avatar:not(:first-child) {
    margin-left: -10px;
  }
  .hero__social-text {
    font-size: 13px;
    color: var(--rg-ink-soft);
  }
  .hero__social-text strong {
    color: var(--rg-ink);
  }
  .hero__art {
    position: relative;
    width: 100%;
    /* Same intrinsic proportion as the heart's original viewBox so the
       normalized clipPath stays heart-shaped instead of stretching. */
    aspect-ratio: 400 / 380;
  }
  /* Off-screen container for the <defs>/<clipPath> — present in the DOM so
     CSS `clip-path: url(#hero-heart)` can reference it, but takes no space. */
  .hero__art-defs {
    position: absolute;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  /* BlurImage wrapper (passed wrapperClass="hero__art-photo"). `:global()`
     because the rendered <span> lives in BlurImage's CSS scope, not ours.
     Clipping the wrapper masks both the responsive <img> and the LQIP
     blur layer beneath it, so the heart silhouette is the only visible
     shape — no rectangular halo behind the cat. */
  .hero__art :global(.hero__art-photo) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    clip-path: url(#hero-heart);
  }
  /* Bruxa's face sits low-right in the source frame; `object-position` lands
     her eyes in the right lobe of the heart instead of near the narrow
     point at the bottom. The wider heart silhouette now does most of the
     compositional work, so the source image displays at its natural cover
     scale — no extra zoom — and her head reads as part of a scene rather
     than dominating the frame. */
  .hero__art :global(.hero__art-photo-img) {
    object-position: 58% 42%;
  }
  /* Stroked outline sits above the photo. `pointer-events: none` so the
     SVG never intercepts clicks on anything below it. */
  .hero__art-outline {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .hero__pillars {
    background: var(--rg-surface);
    border-radius: 18px;
    padding: 22px;
    border: 1px solid var(--rg-border);
    box-shadow: var(--rg-shadow-sm);
  }
  .hero__pillar {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--rg-border);
  }
  .hero__pillar:nth-of-type(3) {
    border-bottom: none;
  }
  .hero__pillar-icon {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__pillar-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--rg-ink);
  }
  .hero__pillar-desc {
    font-size: 12px;
    color: var(--rg-ink-soft);
    line-height: 1.45;
  }
  .hero__pillar-footer {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed var(--rg-border-strong);
    font-family: var(--rg-font-accent);
    font-size: 17px;
    color: var(--rg-primary);
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  @media (max-width: 980px) {
    .hero {
      padding: 36px 22px;
    }
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__art {
      max-width: 360px;
      margin: 0 auto;
    }
    .hero__title {
      font-size: 44px;
    }
  }
</style>
